# Cloudflare _headers - Static Asset Content-Type Enforcement
# This prevents crawlers from misidentifying image URLs as HTML pages.
# It does NOT block image indexing in Google Images (no noimageindex).

/img/*.webp
  Content-Type: image/webp
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/img/*.png
  Content-Type: image/png
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/img/*.jpg
  Content-Type: image/jpeg
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/img/*.svg
  Content-Type: image/svg+xml
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

/assets/*
  Cache-Control: public, max-age=31536000, immutable
  X-Content-Type-Options: nosniff

# Default security headers for all pages
/*
  X-Frame-Options: DENY
  X-Content-Type-Options: nosniff
  Referrer-Policy: strict-origin-when-cross-origin
